{
    "$schema": "/etc/xdg/swaync/configSchema.json",
    "positionX": "right",
    "positionY": "top",
    "layer": "overlay",
    "control-center-margin-top": 8,
    "control-center-margin-bottom": 8,
    "control-center-margin-right": 8,
    "control-center-margin-left": 8,
    "notification-body-image-height": 100,
    "notification-body-image-width": 200,
    "timeout": 10,
    "timeout-low": 5,
    "timeout-critical": 0,
    "fit-to-screen": true,
    "control-center-width": 400,
    "control-center-height": 850,
    "notification-window-width": 400,
    "keyboard-shortcuts": true,
    "image-visibility": "always",
    "transition-time": 200,
    "hide-on-clear": false,
    "hide-on-action": true,
    "script-fail-notify": true,
    "cssPriority": "user",
    "widgets": ["title", "dnd", "mpris", "volume", "backlight", "buttons-grid", "notifications"],
    "widget-config": {
        "title": {
            "text": "Notifications",
            "clear-all-button": true,
            "button-text": "󰎟"
        },
        "dnd": {
            "text": "Do Not Disturb"
        },
        "volume": {
            "label": "󰕾"
        },
        "backlight": {
            "device": "nvidia_wmi_ec_backlight",
            "label": "󰃠"
        },
        "mpris": {
            "show-album-art": "when-available",
            "autohide": true
        },
        "buttons-grid": {
            "actions": [
                {
                    "label": " ",
                    "command": "nm-connection-editor"
                },
                {
                    "label": "󰂯",
                    "command": "blueman-manager"
                },
                {
                    "label": "󰕾",
                    "command": "pavucontrol"
                },
                {
                    "label": "󰹑 ",
                    "command": "grimblast --notify copy area"
                },
                {
                    "label": "󰌾 ",
                    "command": "hyprlock"
                },
                {
                    "label": " ",
                    "command": "sh ~/.config/hypr/scripts/timeout_selector.sh"
                },
                {
                    "label": " ",
                    "command": "sh ~/.config/hypr/scripts/power_profile_selector.sh"
                },
                {
                    "label": "",
                    "command": "wlogout"
                },
                {
                    "label": " ",
                    "command": "sh ~/.config/hypr/scripts/rgb_keyboard_selector.sh"
                }
            ]
        }
    }
}
